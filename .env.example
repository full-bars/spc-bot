# Required
DISCORD_TOKEN=your_bot_token_here

# Required — no defaults, bot will not start without these
SPC_CHANNEL_ID=your_spc_channel_id
MODELS_CHANNEL_ID=your_models_channel_id
GUILD_ID=your_guild_id

# Optional — these have sensible defaults
# HEALTH_CHANNEL_ID=your_health_channel_id (defaults to SPC_CHANNEL_ID)
# SOUNDING_CHANNEL_ID=your_sounding_channel_id (defaults to SPC_CHANNEL_ID)
# CACHE_DIR=cache
# LOG_FILE=spc_bot.log
# MANUAL_CACHE_FILE=posted_records.json
# AUTO_CACHE_FILE=auto_posted_records.json

# Upstash Redis (for failover coordination)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Failover
IS_PRIMARY=true
FAILOVER_TOKEN=your-shared-secret-here
STATE_PORT=8765
